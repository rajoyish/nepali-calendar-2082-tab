{
  "name": "nepali-calendar-2083",
  "private": true,
  "version": "4.0.0",
  "type": "module",
  "scripts": {
    "build:calendar": "node scripts/build-calendar.js",
    "watch:calendar": "nodemon --watch src/data/calendar-2083 --ext json --exec \"npm run build:calendar\"",
    "predev": "npm run build:calendar",
    "dev": "concurrently \"npm run watch:calendar\" \"vite\"",
    "prebuild": "npm run build:calendar",
    "build": "vite build",
    "prewatch": "npm run build:calendar",
    "watch": "concurrently \"npm run watch:calendar\" \"vite build --watch\"",
    "preview": "vite preview"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@sbmdkl/nepali-date-converter": "^2.0.4",
    "bootstrap-icons": "^1.13.1"
  }
}